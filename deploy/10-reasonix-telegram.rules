// Allow reasonix-tg to manage its own service unit.
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "reasonix-tg") {
        // unit name is passed as D-Bus detail to polkit
        var unit = action.lookup("unit");
        if (unit == "reasonix-telegram.service") {
            return polkit.Result.YES;
        }
    }
});
