TG_BOT_TOKEN=
DEEPSEEK_API_KEY=
# ALLOWED_USERS=123456789
# REASONIX_BIN=/usr/local/bin/reasonix
# REASONIX_RTK_LOG=miss   # off | miss (fallbacks only) | all
# REASONIX_CTX_LOG=miss   # off | miss (store/sandbox misses) | all (hits + journal errors)
# STATE_DIR=/var/lib/reasonix-telegram
# MAX_OUTPUT_BYTES=524288
# MAX_DURATION_MIN=30
# MODEL=deepseek-v4-flash
# MODE=chat          # "chat" (tools locked, default) or "tool" (full agent access)

# CHAT_RULES_FILE=/path/to/AGENTS.md